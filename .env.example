# =============================================================================
# Idest Monorepo - Environment Variables Reference
# =============================================================================
# This file documents ALL environment variables used across apps.
# Each app maintains its own .env file in its directory.
# Copy the relevant variables to each app's .env as needed.
# =============================================================================

# -----------------------------------------------------------------------------
# SHARED: Used by both NestJS apps (server + assignments)
# Must be identical across apps that share them.
# -----------------------------------------------------------------------------

JWT_SECRET=
JWT_EXPIRES_IN=
JWT_ISSUER=

SUPABASE_URL=
OPENAI_API_KEY=
RABBITMQ_URL=

# -----------------------------------------------------------------------------
# apps/server
# -----------------------------------------------------------------------------

# Postgres (Prisma)
POSTGRES_DB=
POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_PORT=
POSTGRES_HOST=
DATABASE_URL=

NODE_ENV=
PORT=
CORS_ORIGINS=

FRONTEND_BASE_URL=

# Cloudinary
CLOUDINARY_URL=
CLOUDINARY_API_SECRET=
CLOUDINARY_API_KEY=

# Supabase (server-specific keys)
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_DEV_EMAIL=
SUPABASE_DEV_PASSWORD=
SUPABASE_ANON_KEY=

SECRET_PASS=

# URL to the assignments microservice
ASSIGNMENT_URL=

# LiveKit
LIVEKIT_URL=
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# Stripe
STRIPE_PUBLIC_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# LiveKit Recording / Egress
LIVEKIT_RECORDING_LAYOUT=speaker
LIVEKIT_EGRESS_S3_BUCKET=
LIVEKIT_EGRESS_S3_REGION=
LIVEKIT_EGRESS_S3_ACCESS_KEY=
LIVEKIT_EGRESS_S3_SECRET_KEY=
LIVEKIT_EGRESS_S3_ENDPOINT=
LIVEKIT_EGRESS_S3_FORCE_PATH_STYLE=false
RECORDING_PUBLIC_BASE_URL=
RECORDING_URL_EXPIRES_SECONDS=3600

# -----------------------------------------------------------------------------
# apps/assignments
# -----------------------------------------------------------------------------

# MongoDB
MONGODB_URI=
MONGO_PASSWORD=
MONGO_USERNAME=

# PORT (different from server)
# PORT=

API_URL=
SUPABASE_KEY=
FRONTEND_URL=

# -----------------------------------------------------------------------------
# apps/website (Next.js - NEXT_PUBLIC_ prefix for client-side access)
# -----------------------------------------------------------------------------

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_OR_ANON_KEY=
NEXT_PUBLIC_API_URL=
NEXT_PUBLIC_ASSIGNMENT_API_URL=
NEXT_PUBLIC_API_WS_URL=
NEXT_PUBLIC_MEET_URL=
NEXT_PUBLIC_MEET_WS_URL=
NEXT_PUBLIC_CONVERSATION_URL=
NEXT_PUBLIC_TURN_SERVER_URL=
NEXT_PUBLIC_TURN_USERNAME=
NEXT_PUBLIC_TURN_CREDENTIAL=

# -----------------------------------------------------------------------------
# Docker Compose overrides (optional)
# -----------------------------------------------------------------------------

WEBSITE_PORT=3000
SERVER_PORT=8000
AI_URL=http://ai:8001
KOKORO_URL=http://kokoro:8880
